# LAISA Agent OS — Email Configuration
# Copy this to .env and fill in your credentials

# Gmail App Password (NOT your login password)
# Get it at: myaccount.google.com → Security → App Passwords
# Make sure 2-Step Verification is ON first
SMTP_PASS=your_16_character_app_password_here

# Email address to send from
SMTP_USER=info@studexmeat.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ElevenLabs API Key (for Charlie voice agent — optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Twilio (for WhatsApp — optional)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Composio (for social integrations — optional)
COMPOSIO_API_KEY=your_composio_api_key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key