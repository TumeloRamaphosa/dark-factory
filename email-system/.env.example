# OGRE Computer — Email System Configuration
# Copy this file to .env and fill in your credentials
# ⚠️ NEVER commit .env to git — it's already in .gitignore

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Your Gmail address
EMAIL_USER=info@studexmeat.com

# ⚠️ REQUIRED: Your 16-character Gmail App Password
#    See /workspace/email-system/SETUP-GMAIL.md for how to get this
EMAIL_PASS=YOUR_APP_PASSWORD_HERE

# ── Sender / From ─────────────────────────────────────────────────────────────
# Display name shown in email clients
EMAIL_FROM="OGRE Computer" <info@studexmeat.com>

# ── Default recipients ─────────────────────────────────────────────────────────
# Main inbox (evening digest goes here)
EMAIL_TO=info@studexmeat.com

# Tumelo's personal inbox (morning brief + research go here)
EMAIL_TO_TUMELO=tumelo@studexmeat.com

# ── Queue directory ────────────────────────────────────────────────────────────
# Where the cron scripts look for content files
EMAIL_QUEUE_DIR=/workspace/email-queue

# ── Log file (optional, default is ./email.log) ───────────────────────────────
# EMAIL_LOG_FILE=/workspace/email-system/email.log
