# Dark Factory PRD Intake — Environment Variables
# Copy this file to .env and fill in your values

# ── VirusTotal (Required for file + link scanning) ────────────────────────
# Free tier: 4 lookups/minute. Get key at: https://www.virustotal.com/gui/join-us
# Without this key: uploads are stored but not scanned
VIRUSTOTAL_API_KEY=

# ── Notion CRM (Required to create PRD pages in Notion) ────────────────────
# Create integration at: https://www.notion.so/my-integrations
# Share your PRD database with the integration
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Email Notifications (Required for team alerts) ─────────────────────────
# Use Resend: https://resend.com (free tier: 100 emails/day)
# Or any SMTP provider
EMAIL_API_KEY=
EMAIL_FROM=noreply@darkfactory.dev
TEAM_EMAIL=info@studexmeat.com

# ── Server ────────────────────────────────────────────────────────────────
PORT=3099
